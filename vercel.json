{
 "version": 2,
 "buildCommand": "npm run build",
 "installCommand": "npm install",
 "dev": "npm run dev",
 "env": {
   "NODE_ENV": "production"
 },
 "builds": [
  {
   "src": "dist/index.cjs",
   "use": "@vercel/node"
  }
 ],
 "routes": [
  {
   "src": "/(.*)",
   "dest": "dist/index.cjs"
  }
 ]
}
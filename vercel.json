{
 "version": 2,
 "builds": [
  {
   "src": "client/package.json",
   "use": "@vercel/static-build",
   "config": { "distDir": "dist/public" }
  },
  {
   "src": "server/index.ts",
   "use": "@vercel/node",
   "config": { "includeFiles": ["dist/**"] }
  }
 ],
 "routes": [
  {
   "src": "/(.*)",
   "dest": "server/index.ts"
  }
 ]
}